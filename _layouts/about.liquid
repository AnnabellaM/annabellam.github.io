---
layout: default
---
<div class="about">
  <!-- Hero: avatar + identity + links (left), bio (right) -->
  <section class="about-hero" id="about">
    <div class="about-hero-inner">
      <div class="row align-items-start">
        <div class="col-md-4 about-profile text-center">
          {% if page.profile and page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid avatar-img avatar-circular' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid avatar-img' %}
            {% endif %}
            <div class="avatar-wrapper">
              {%
                include figure.liquid loading="eager" path=profile_image_path class=profile_image_class alt=page.profile.image
                cache_bust=true
              %}
            </div>
          {% endif %}

          <h1 class="about-name">
            {% if page.profile.name %}
              {{ page.profile.name }}
            {% elsif site.title == 'blank' %}
              {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}
            {% else %}
              {{ site.title }}
            {% endif %}
          </h1>

          {% if page.profile.position %}
            <p class="about-position">{{ page.profile.position }}</p>
          {% endif %}

          {% if page.profile.affiliations %}
            {% for affiliation in page.profile.affiliations %}
              <p class="about-affiliation">
                {% if affiliation.url %}
                  <a href="{{ affiliation.url }}" target="_blank" rel="noopener">{{ affiliation.name }}</a>
                {% else %}
                  {{ affiliation.name }}
                {% endif %}
              </p>
            {% endfor %}
          {% endif %}

          {% if page.profile.more_info %}
            <div class="more-info">{{ page.profile.more_info }}</div>
          {% endif %}

          {% if page.social %}
            <div class="about-social">{% include social.liquid %}</div>
          {% endif %}
        </div>

        <div class="col-md-8 about-bio">{{ content }}</div>
      </div>
    </div>
  </section>

  <article>
    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <section class="about-section" id="news">
        <h2 class="section-heading">News</h2>
        {% include news.liquid limit=true %}
      </section>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <section class="about-section">
        <h2 class="section-heading">
          <a href="{{ '/blog/' | relative_url }}">Latest Posts</a>
        </h2>
        {% include latest_posts.liquid %}
      </section>
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <section class="about-section" id="publications">
        <h2 class="section-heading">Publications</h2>
        <div class="publications">
          {% bibliography --group_by none %}
        </div>
      </section>
    {% endif %}

    <!-- Teaching / Services / Awards: content sourced from their _pages files -->
    {% assign teaching_page = site.pages | where: 'permalink', '/teaching/' | first %}
    {% if teaching_page %}
      <section class="about-section" id="teaching">
        <h2 class="section-heading">Teaching</h2>
        {{ teaching_page.content | markdownify }}
      </section>
    {% endif %}

    {% assign services_page = site.pages | where: 'permalink', '/service/' | first %}
    {% if services_page %}
      <section class="about-section" id="services">
        <h2 class="section-heading">Services</h2>
        {{ services_page.content | markdownify }}
      </section>
    {% endif %}

    {% assign awards_page = site.pages | where: 'permalink', '/awards/' | first %}
    {% if awards_page %}
      <section class="about-section" id="awards">
        <h2 class="section-heading">Awards</h2>
        {{ awards_page.content | markdownify }}
      </section>
    {% endif %}

    <!-- Visitor globe (UmamiMaps) — renders only when the endpoint is configured -->
    {% if site.visitor_globe_endpoint %}
      <div class="visitor-map mt-4" style="text-align: center;">
        <div id="visitor-globe" style="display: inline-block;"></div>
      </div>
      <script
        src="https://unpkg.com/umami-maps/dist/embed.global.js"
        data-endpoint="{{ site.visitor_globe_endpoint }}"
        data-target="#visitor-globe"
        data-size="250"
      ></script>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
