<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container-fluid px-3">
      <a class="navbar-brand title" href="{{ site.baseurl }}/">
        {% if site.title == 'blank' %}
          {% if site.first_name %}
            <span class="font-weight-bold">
              {{- site.first_name -}}
            </span>
          {% endif %}
          {% if site.middle_name %}
            {{- site.middle_name -}}
          {% endif %}
          {% if site.last_name %}
            {{- site.last_name -}}
          {% endif %}
        {% else %}
          {{- site.title -}}
        {% endif %}
      </a>
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <!-- Single-page anchor tabs; the active tab is set by the scrollspy script below -->
        <ul class="navbar-nav mr-auto flex-nowrap">
          <li class="nav-item">
            <a class="nav-link" href="{{ '/#about' | relative_url }}">About</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ '/#publications' | relative_url }}">Publications</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ '/#teaching' | relative_url }}">Teaching</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ '/#services' | relative_url }}">Services</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ '/#awards' | relative_url }}">Awards</a>
          </li>
        </ul>
        <ul class="navbar-nav ml-auto flex-nowrap">
          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">ctrl k <i class="ti ti-search"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <!-- Toogle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="ti ti-sun-moon" id="light-toggle-system"></i>
                <i class="ti ti-moon-filled" id="light-toggle-dark"></i>
                <i class="ti ti-sun-filled" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}

  <!-- Scrollspy: highlight the tab of the section currently in view -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var items = Array.prototype.slice.call(document.querySelectorAll('#navbarNav .navbar-nav li.nav-item'));
      var pairs = [];
      items.forEach(function (li) {
        var link = li.querySelector('a.nav-link');
        var hash = link && (link.getAttribute('href') || '').split('#')[1];
        var section = hash && document.getElementById(hash);
        if (section) pairs.push({ li: li, section: section });
      });
      if (!pairs.length) return; // sections only exist on the single-page home
      function onScroll() {
        var pos = window.scrollY + 120; // fixed navbar height + breathing room
        var current = pairs[0];
        pairs.forEach(function (p) {
          if (p.section.offsetTop <= pos) current = p;
        });
        if (window.innerHeight + window.scrollY >= document.body.scrollHeight - 2) {
          current = pairs[pairs.length - 1];
        }
        items.forEach(function (li) {
          li.classList.toggle('active', li === current.li);
        });
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    });
  </script>
</header>
